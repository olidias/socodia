---
// ProjectCard.astro
// Props: title, period, role, tech, highlights (array)
const { title, period, role, tech, highlights } = Astro.props;
---
<article class="bg-white dark:bg-slate-800 shadow-md mb-8 p-6 rounded-lg">
  <h2 class="mb-2 font-bold text-primary dark:text-blue-200 text-xl">{title}</h2>
  <div class="mb-1 text-slate-500 dark:text-slate-300 text-sm">
    <span>{period}</span> | <span class="italic">{role}</span>
  </div>
  <div class="mb-2 text-sm"><span class="font-semibold">Tech:</span> {tech}</div>
  <ul class="space-y-1 pl-5 list-disc">
    {highlights && highlights.map ? highlights.map((h, i) => <li key={i}>{h}</li>) : null}
  </ul>
</article>
