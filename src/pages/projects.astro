---
import PageLayout from '~/layouts/PageLayout.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import { getLangFromUrl, useTranslations } from '~/i18n/utils.js';
import { Icon } from 'astro-icon';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<PageLayout>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-b from-blue-50 to-white dark:from-slate-800 dark:to-slate-900 pt-20 pb-16">
    <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.05]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%231e40af&quot; fill-opacity=&quot;0.4&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-base text-primaryLight dark:text-blue-200 font-semibold tracking-wide uppercase mb-3">Portfolio</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-gray-900 dark:text-white leading-tight tracking-tighter mb-6">
        {t('projects.title')}
      </h1>
      <p class="mx-auto max-w-3xl text-lg text-muted dark:text-slate-400 leading-relaxed">
        {t('projects.intro')}
      </p>
    </div>
  </section>

  <!-- Leadership Callout -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 -mt-8 mb-12 relative z-10">
    <div class="flex items-start gap-4 bg-white dark:bg-slate-800 border border-primary/10 dark:border-blue-400/10 rounded-xl p-6 shadow-lg">
      <div class="shrink-0 flex items-center justify-center w-10 h-10 rounded-lg bg-primary/10 dark:bg-blue-400/10">
        <Icon name="tabler:users" class="w-5 h-5 text-primary dark:text-blue-300" />
      </div>
      <div>
        <h3 class="font-semibold text-gray-900 dark:text-white mb-1">People Leadership</h3>
        <p class="text-sm text-muted dark:text-slate-400">{t('projects.leadership')}</p>
      </div>
    </div>
  </section>

  <!-- Project Cards -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-8">
    <div class="grid gap-6 md:grid-cols-2">
      <ProjectCard
        title={t('projects.webapp_roads.title')}
        period={t('projects.webapp_roads.period')}
        role={t('projects.webapp_roads.role')}
        tech={t('projects.webapp_roads.tech')}
        highlights={[t('projects.webapp_roads.highlight1'), t('projects.webapp_roads.highlight2'), t('projects.webapp_roads.highlight3'), t('projects.webapp_roads.highlight4'), t('projects.webapp_roads.highlight5')]}
      />
      <ProjectCard
        title={t('projects.oprisk.title')}
        period={t('projects.oprisk.period')}
        role={t('projects.oprisk.role')}
        tech={t('projects.oprisk.tech')}
        highlights={[t('projects.oprisk.highlight1'), t('projects.oprisk.highlight2'), t('projects.oprisk.highlight3'), t('projects.oprisk.highlight4'), t('projects.oprisk.highlight5')]}
      />
      <ProjectCard
        title={t('projects.advisory.title')}
        period={t('projects.advisory.period')}
        role={t('projects.advisory.role')}
        tech={t('projects.advisory.tech')}
        highlights={[t('projects.advisory.highlight1'), t('projects.advisory.highlight2'), t('projects.advisory.highlight3'), t('projects.advisory.highlight4')]}
      />
      <ProjectCard
        title={t('projects.archreview.title')}
        period={t('projects.archreview.period')}
        role={t('projects.archreview.role')}
        tech={t('projects.archreview.tech')}
        highlights={[t('projects.archreview.highlight1'), t('projects.archreview.highlight2'), t('projects.archreview.highlight3')]}
      />
      <ProjectCard
        title={t('projects.webprojects.title')}
        period={t('projects.webprojects.period')}
        role={t('projects.webprojects.role')}
        tech={t('projects.webprojects.tech')}
        highlights={[t('projects.webprojects.highlight1'), t('projects.webprojects.highlight2'), t('projects.webprojects.highlight3')]}
      />
    </div>
  </section>

  <!-- CTA Section -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20">
    <div class="text-center bg-gradient-to-r from-primary/5 via-primary/10 to-primary/5 dark:from-blue-400/5 dark:via-blue-400/10 dark:to-blue-400/5 rounded-2xl py-12 px-6">
      <p class="text-xl font-medium text-gray-900 dark:text-white mb-6">{t('projects.cta')}</p>
      <a href="/#contact" class="btn btn-primary">
        {t('projects.ctaButton')}
      </a>
    </div>
  </section>
</PageLayout>
